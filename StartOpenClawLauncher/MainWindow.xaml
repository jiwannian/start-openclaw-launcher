<Window x:Class="StartOpenClawLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OpenClaw 启停助手"
        Width="860"
        Height="640"
        MinWidth="760"
        MinHeight="580"
        WindowStartupLocation="CenterScreen"
        Background="#FFF6F8FB">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Padding="18"
                Background="White"
                CornerRadius="16"
                BorderBrush="#FFE3E8EF"
                BorderThickness="1">
            <StackPanel>
                <TextBlock FontSize="26"
                           FontWeight="SemiBold"
                           Foreground="#FF1F2937"
                           Text="OpenClaw 启停助手" />
                <TextBlock Margin="0,8,0,0"
                           Foreground="#FF5B6472"
                           Text="一键启动 Clash（如已安装）与 OpenClaw；一键关闭 OpenClaw。" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Padding="16" Background="White" CornerRadius="14" BorderBrush="#FFE3E8EF" BorderThickness="1">
                <StackPanel>
                    <TextBlock FontWeight="SemiBold" Foreground="#FF374151" Text="Clash 状态" />
                    <TextBlock x:Name="ClashStatusTextBlock" Margin="0,8,0,0" FontSize="18" FontWeight="SemiBold" Text="检测中..." />
                    <TextBlock x:Name="ClashDetailTextBlock" Margin="0,6,0,0" Foreground="#FF6B7280" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Padding="16" Background="White" CornerRadius="14" BorderBrush="#FFE3E8EF" BorderThickness="1">
                <StackPanel>
                    <TextBlock FontWeight="SemiBold" Foreground="#FF374151" Text="代理状态" />
                    <TextBlock x:Name="ProxyStatusTextBlock" Margin="0,8,0,0" FontSize="18" FontWeight="SemiBold" Text="检测中..." />
                    <TextBlock x:Name="ProxyDetailTextBlock" Margin="0,6,0,0" Foreground="#FF6B7280" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Grid.Column="4" Padding="16" Background="White" CornerRadius="14" BorderBrush="#FFE3E8EF" BorderThickness="1">
                <StackPanel>
                    <TextBlock FontWeight="SemiBold" Foreground="#FF374151" Text="OpenClaw 状态" />
                    <TextBlock x:Name="OpenClawStatusTextBlock" Margin="0,8,0,0" FontSize="18" FontWeight="SemiBold" Text="检测中..." />
                    <TextBlock x:Name="OpenClawDetailTextBlock" Margin="0,6,0,0" Foreground="#FF6B7280" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Margin="0,16,0,0"
                Padding="18"
                Background="White"
                CornerRadius="16"
                BorderBrush="#FFE3E8EF"
                BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Button x:Name="StartButton"
                        Grid.Row="0"
                        Grid.Column="0"
                        Height="54"
                        FontSize="17"
                        FontWeight="SemiBold"
                        Foreground="White"
                        Background="#FF2563EB"
                        BorderBrush="#FF2563EB"
                        Content="一键启动 OpenClaw"
                        Click="StartButton_Click" />

                <Button x:Name="StopButton"
                        Grid.Row="0"
                        Grid.Column="2"
                        Height="54"
                        FontSize="17"
                        FontWeight="SemiBold"
                        Foreground="White"
                        Background="#FFDC2626"
                        BorderBrush="#FFDC2626"
                        Content="一键关闭 OpenClaw"
                        Click="StopButton_Click" />

                <TextBlock x:Name="HintTextBlock"
                           Grid.Row="1"
                           Grid.ColumnSpan="3"
                           Margin="0,14,0,0"
                           Foreground="#FF6B7280"
                           Text="启动按钮会先检查 Clash，再检查 OpenClaw；若未检测到 OpenClaw，将打开官方安装页面。"
                           TextWrapping="Wrap" />

                <Grid Grid.Row="2"
                      Grid.ColumnSpan="3"
                      Margin="0,14,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Padding="14"
                            Background="#FFF9FAFB"
                            CornerRadius="12"
                            BorderBrush="#FFE5E7EB"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold"
                                       Foreground="#FF374151"
                                       Text="访问地址" />
                            <TextBlock x:Name="AccessUrlTextBlock"
                                       Margin="0,8,0,0"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="#FF2563EB"
                                       Text="http://127.0.0.1:18789/"
                                       TextWrapping="Wrap" />
                            <TextBlock Margin="0,6,0,0"
                                       Foreground="#FF6B7280"
                                       Text="检测到 OpenClaw 运行后，将自动在浏览器打开该地址。"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2"
                            Padding="14"
                            Background="#FFF9FAFB"
                            CornerRadius="12"
                            BorderBrush="#FFE5E7EB"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold"
                                       Foreground="#FF374151"
                                       Text="运行时长" />
                            <TextBlock x:Name="RuntimeValueTextBlock"
                                       Margin="0,8,0,0"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="#FF111827"
                                       Text="未运行" />
                            <TextBlock x:Name="RuntimeDetailTextBlock"
                                       Margin="0,6,0,0"
                                       Foreground="#FF6B7280"
                                       Text="启动后将自动开始计时。"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="3"
                Margin="0,16,0,0"
                Padding="16"
                Background="White"
                CornerRadius="16"
                BorderBrush="#FFE3E8EF"
                BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="#FF374151"
                           Text="运行日志" />

                <TextBox x:Name="LogTextBox"
                         Grid.Row="1"
                         Margin="0,12,0,0"
                         Padding="12"
                         FontFamily="Consolas, Microsoft YaHei UI"
                         FontSize="13"
                         Foreground="#FF111827"
                         Background="#FFF9FAFB"
                         BorderBrush="#FFE5E7EB"
                         BorderThickness="1"
                         IsReadOnly="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         TextWrapping="Wrap"
                         AcceptsReturn="True" />
            </Grid>
        </Border>
    </Grid>
</Window>
