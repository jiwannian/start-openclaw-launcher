<Window x:Class="StartOpenClawLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OpenClaw Desktop Launcher"
        Width="920"
        Height="700"
        MinWidth="820"
        MinHeight="620"
        WindowStartupLocation="CenterScreen"
        Background="#FFF6F8FB">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Padding="18"
                Background="White"
                CornerRadius="16"
                BorderBrush="#FFE3E8EF"
                BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center">
                    <TextBlock x:Name="LanguageLabelTextBlock"
                               Margin="0,0,10,0"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold"
                               Foreground="#FF374151"
                               Text="Language" />
                    <ComboBox x:Name="LanguageComboBox"
                              Width="180"
                              VerticalAlignment="Center"
                              DisplayMemberPath="DisplayName"
                              SelectionChanged="LanguageComboBox_SelectionChanged" />
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="0,16,0,0">
                    <TextBlock x:Name="HeaderTitleTextBlock"
                               FontSize="26"
                               FontWeight="SemiBold"
                               Foreground="#FF1F2937"
                               Text="OpenClaw Desktop Launcher" />
                    <TextBlock x:Name="HeaderSubtitleTextBlock"
                               Margin="0,8,0,0"
                               Foreground="#FF5B6472"
                               Text="Start Clash and OpenClaw with one click, and stop OpenClaw with one click."
                               TextWrapping="Wrap" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Padding="16" Background="White" CornerRadius="14" BorderBrush="#FFE3E8EF" BorderThickness="1">
                <StackPanel>
                    <TextBlock x:Name="ClashCardTitleTextBlock" FontWeight="SemiBold" Foreground="#FF374151" Text="Clash Status" />
                    <TextBlock x:Name="ClashStatusTextBlock" Margin="0,8,0,0" FontSize="18" FontWeight="SemiBold" Text="Checking..." />
                    <TextBlock x:Name="ClashDetailTextBlock" Margin="0,6,0,0" Foreground="#FF6B7280" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Padding="16" Background="White" CornerRadius="14" BorderBrush="#FFE3E8EF" BorderThickness="1">
                <StackPanel>
                    <TextBlock x:Name="ProxyCardTitleTextBlock" FontWeight="SemiBold" Foreground="#FF374151" Text="Proxy Status" />
                    <TextBlock x:Name="ProxyStatusTextBlock" Margin="0,8,0,0" FontSize="18" FontWeight="SemiBold" Text="Checking..." />
                    <TextBlock x:Name="ProxyDetailTextBlock" Margin="0,6,0,0" Foreground="#FF6B7280" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Grid.Column="4" Padding="16" Background="White" CornerRadius="14" BorderBrush="#FFE3E8EF" BorderThickness="1">
                <StackPanel>
                    <TextBlock x:Name="OpenClawCardTitleTextBlock" FontWeight="SemiBold" Foreground="#FF374151" Text="OpenClaw Status" />
                    <TextBlock x:Name="OpenClawStatusTextBlock" Margin="0,8,0,0" FontSize="18" FontWeight="SemiBold" Text="Checking..." />
                    <TextBlock x:Name="OpenClawDetailTextBlock" Margin="0,6,0,0" Foreground="#FF6B7280" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Margin="0,16,0,0"
                Padding="18"
                Background="White"
                CornerRadius="16"
                BorderBrush="#FFE3E8EF"
                BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Button x:Name="StartButton"
                        Grid.Row="0"
                        Grid.Column="0"
                        Height="54"
                        FontSize="17"
                        FontWeight="SemiBold"
                        Foreground="White"
                        Background="#FF2563EB"
                        BorderBrush="#FF2563EB"
                        Content="Start OpenClaw"
                        Click="StartButton_Click" />

                <Button x:Name="StopButton"
                        Grid.Row="0"
                        Grid.Column="2"
                        Height="54"
                        FontSize="17"
                        FontWeight="SemiBold"
                        Foreground="White"
                        Background="#FFDC2626"
                        BorderBrush="#FFDC2626"
                        Content="Stop OpenClaw"
                        Click="StopButton_Click" />

                <TextBlock x:Name="HintTextBlock"
                           Grid.Row="1"
                           Grid.ColumnSpan="3"
                           Margin="0,14,0,0"
                           Foreground="#FF6B7280"
                           Text="The start button checks Clash first, then OpenClaw; if OpenClaw is missing, the official install page opens."
                           TextWrapping="Wrap" />

                <Grid Grid.Row="2"
                      Grid.ColumnSpan="3"
                      Margin="0,14,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Padding="14"
                            Background="#FFF9FAFB"
                            CornerRadius="12"
                            BorderBrush="#FFE5E7EB"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock x:Name="AccessCardTitleTextBlock"
                                       FontWeight="SemiBold"
                                       Foreground="#FF374151"
                                       Text="Access URL" />
                            <TextBlock x:Name="AccessUrlTextBlock"
                                       Margin="0,8,0,0"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="#FF2563EB"
                                       Text="http://127.0.0.1:18789/"
                                       TextWrapping="Wrap" />
                            <TextBlock x:Name="AccessDescriptionTextBlock"
                                       Margin="0,6,0,0"
                                       Foreground="#FF6B7280"
                                       Text="When OpenClaw is confirmed running, this URL opens automatically in your browser."
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2"
                            Padding="14"
                            Background="#FFF9FAFB"
                            CornerRadius="12"
                            BorderBrush="#FFE5E7EB"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock x:Name="RuntimeCardTitleTextBlock"
                                       FontWeight="SemiBold"
                                       Foreground="#FF374151"
                                       Text="Runtime Duration" />
                            <TextBlock x:Name="RuntimeValueTextBlock"
                                       Margin="0,8,0,0"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="#FF111827"
                                       Text="Not running" />
                            <TextBlock x:Name="RuntimeDetailTextBlock"
                                       Margin="0,6,0,0"
                                       Foreground="#FF6B7280"
                                       Text="The timer starts automatically after launch."
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="3"
                Margin="0,16,0,0"
                Padding="16"
                Background="White"
                CornerRadius="16"
                BorderBrush="#FFE3E8EF"
                BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock x:Name="LogsTitleTextBlock"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="#FF374151"
                           Text="Runtime Logs" />

                <TextBox x:Name="LogTextBox"
                         Grid.Row="1"
                         Margin="0,12,0,0"
                         Padding="12"
                         FontFamily="Consolas, Microsoft YaHei UI"
                         FontSize="13"
                         Foreground="#FF111827"
                         Background="#FFF9FAFB"
                         BorderBrush="#FFE5E7EB"
                         BorderThickness="1"
                         IsReadOnly="True"
                         VerticalScrollBarVisibility="Auto"
                         TextWrapping="Wrap" />
            </Grid>
        </Border>
    </Grid>
</Window>
